{
  "name": "cleanmyproj",
  "version": "1.3.0",
  "type": "module",
  "description": "CLI tool to clean project caches and free up local storage",
  "exports": "./dist/index.js",
  "bin": {
    "cmpj": "bin/cmpj.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
